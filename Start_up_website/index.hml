<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Neurotrace Logo Animation</title>
    <style>
        /* General Setup */
        body {
            display: grid;
            place-items: center;
            min-height: 100vh;
            background-color: #ffffff;
            font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
            overflow: hidden;
        }

        /* Main Logo Container */
        .logo-container {
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px; /* Reduced gap for smaller image */
        }

        /* Bubble Container - Wider spread and adjusted height */
        .bubble-wrapper {
            position: absolute;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 100%; /* Make it wider to cover more space */
            max-width: 500px; /* Adjust max-width as needed */
            height: 400px; /* Allow bubbles to move further up */
            pointer-events: none; /* Allows clicking through */
            z-index: 1;
        }

        .bubble {
            position: absolute;
            border: 2px solid hsla(195, 53%, 79%, 0.5); /* Light blue/teal border */
            border-radius: 50%;
            opacity: 0; /* Hidden by default */
            background-color: rgba(255, 255, 255, 0.1);
            
            animation-name: floatUp;
            animation-timing-function: ease-in-out;
            animation-iteration-count: infinite;
            animation-play-state: paused;
        }

        .bubble.animate {
            animation-play-state: running;
        }

        /* Bubble Animation Keyframes - Adjusted translateY for wider spread */
        @keyframes floatUp {
            0% {
                transform: translateY(20px);
                opacity: 0;
            }
            10% {
                opacity: 0.7;
            }
            90% {
                opacity: 0.7;
            }
            100% {
                transform: translateY(-350px); /* Bubbles move further up */
                opacity: 0;
            }
        }

        /* --- IMAGE BRAIN --- */
        .brain-wrapper {
            width: 300px; /* <-- CHANGED: Made smaller */
            height: 300px; /* <-- CHANGED: Made smaller */
            position: relative; /* Needed for absolute positioning of bubbles within it */
            z-index: 5;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer; /* Indicate it's clickable */
        }

        .brain-image {
            width: 100%;
            height: 100%;
            object-fit: contain; 
        }

        /* Bubbles inside the brain */
        .brain-bubble-wrapper {
            position: absolute;
            width: 100%;
            height: 100%;
            overflow: hidden; /* Keep bubbles within the brain bounds */
            pointer-events: none; /* Allows clicking through to the brain image */
            z-index: 6; /* Above the brain image */
        }

        .brain-bubble {
            position: absolute;
            background-color: rgba(0, 150, 255, 0.6); /* Blueish glow */
            border-radius: 50%;
            opacity: 0;
            filter: blur(2px);
            animation-name: brainPulse;
            animation-timing-function: ease-in-out;
            animation-iteration-count: infinite;
            animation-play-state: paused;
        }

        .brain-bubble.animate {
            animation-play-state: running;
        }

        @keyframes brainPulse {
            0% {
                transform: scale(0.5);
                opacity: 0;
            }
            50% {
                transform: scale(1.2);
                opacity: 0.8;
            }
            100% {
                transform: scale(1.5);
                opacity: 0;
            }
        }

        /* Text Styling */
        .text {
            text-align: center;
            z-index: 5; /* In front of bubbles */
            /* Removed margin-top to rely on the container gap */
        }

        .title {
            font-size: 2.5rem;
            font-weight: 700;
            letter-spacing: 1px;
            margin: 0;
        }

        .title .blue {
            color: #2a8dcb;
        }
        .title .gray {
            color: #556270;
        }

        .subtitle {
            font-size: 1rem;
            font-weight: 400;
            color: #777;
            margin: 5px 0 0 0;
            letter-spacing: 0.5px;
        }

    </style>
</head>
<body>

    <div class="logo-container">
        
        <div class="bubble-wrapper" id="outer-bubble-wrapper"></div>

        <div class="brain-wrapper" id="brain-wrapper">
            <img src="https://cdn-icons-png.flaticon.com/512/6049/6049928.png" class="brain-image" alt="Brain Icon">
            <div class="brain-bubble-wrapper" id="inner-bubble-wrapper"></div>
        </div>

        <div class="text">
            <h1 class="title">
                <span class="blue">NEURO</span><span class="gray">TRACE</span>
            </h1>
            <p class="subtitle">High-Resolution Brain Mapping</p>
        </div>

    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const brainWrapper = document.getElementById('brain-wrapper');
            const outerBubbleWrapper = document.getElementById('outer-bubble-wrapper');
            const innerBubbleWrapper = document.getElementById('inner-bubble-wrapper');
            const numOuterBubbles = 20; // How many bubbles to create outside
            const numInnerBubbles = 10; // How many bubbles to create inside the brain
            let animationsRunning = false;

            // Create outer bubbles
            for (let i = 0; i < numOuterBubbles; i++) {
                const bubble = document.createElement('div');
                bubble.className = 'bubble';
                
                const size = Math.random() * 20 + 5;
                bubble.style.width = `${size}px`;
                bubble.style.height = `${size}px`;
                
                bubble.style.left = `${Math.random() * 90 + 5}%`; // Wider horizontal spread
                bubble.style.top = `${Math.random() * 20 + 80}%`;
                
                bubble.style.animationDelay = `${Math.random() * 5}s`;
                bubble.style.animationDuration = `${Math.random() * 4 + 4}s`;
                
                outerBubbleWrapper.appendChild(bubble);
            }

            // Create inner bubbles (for the brain)
            for (let i = 0; i < numInnerBubbles; i++) {
                const bubble = document.createElement('div');
                bubble.className = 'brain-bubble';
                
                const size = Math.random() * 10 + 5; // Smaller bubbles inside
                bubble.style.width = `${size}px`;
                bubble.style.height = `${size}px`;
                
                // Position randomly within the brain image area (approximately)
                bubble.style.left = `${Math.random() * 80 + 10}%`; 
                bubble.style.top = `${Math.random() * 80 + 10}%`;
                
                bubble.style.animationDelay = `${Math.random() * 2}s`;
                bubble.style.animationDuration = `${Math.random() * 1 + 1}s`; // Faster pulse
                
                innerBubbleWrapper.appendChild(bubble);
            }

            // Add click event to the brain image
            brainWrapper.addEventListener('click', () => {
                const outerBubbles = outerBubbleWrapper.querySelectorAll('.bubble');
                const innerBubbles = innerBubbleWrapper.querySelectorAll('.brain-bubble');
                
                animationsRunning = !animationsRunning; // Toggle state

                outerBubbles.forEach(bubble => {
                    if (animationsRunning) {
                        bubble.classList.add('animate');
                    } else {
                        bubble.classList.remove('animate');
                    }
                });

                innerBubbles.forEach(bubble => {
                    if (animationsRunning) {
                        bubble.classList.add('animate');
                    } else {
                        bubble.classList.remove('animate');
                    }
                });
            });
        });
    </script>

</body>
</html>